# Supabase (auto-injected in Edge Functions, needed for local dev)
SUPABASE_URL=https://hbzgupcwrzncvskyhyoc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Meta Ads
META_ACCESS_TOKEN=          # EAABxxxxx — valid 60 days, renew via Meta Developer Portal
AD_ACCOUNT_ID=              # act_1234567890
DAILY_AD_BUDGET=            # daily budget in USD (e.g. 50) — used to detect spend > 110% overage

# Twilio (WhatsApp)
TWILIO_SID=                 # ACxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=               # +1234567890 (Twilio WhatsApp sender)
RECIPIENT_PHONE=            # +your_number (must be verified in Twilio sandbox)

# SendGrid (Email)
SENDGRID_API_KEY=           # SG.xxxxxxx
SENDER_EMAIL=               # alerts@yourdomain.com (must be verified in SendGrid)
RECIPIENT_EMAIL=            # your@email.com

# Slack
SLACK_WEBHOOK_URL=          # https://hooks.slack.com/services/T.../B.../xxx
